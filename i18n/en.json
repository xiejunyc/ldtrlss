  "ui.aboutGearScore.header": "About Gear Score",
  "ui.aboutGearScore.intro": "The displayed \"gearscore\" is made up of two components: Gear Score and Upgrade Score",
  "ui.aboutGearScore.gearScore1": "Gear Score ranges between 0 and 100 and 106.",
  "ui.aboutGearScore.gearScore2": "100 is the reference value meaning a fully exotic set with all stats selected.",
  "ui.aboutGearScore.gearScore3": "106 on the other hand is ascended, the 6 bonus points refer to the percentual stat increase.",
  "ui.aboutGearScore.gearScore4": "When no stats are selected the gear score does not increase, as no stats are gained. (Defense is ignored.)",
  "ui.aboutGearScore.upgradeScore1": "Upgrade Score ranges between 0 and 100.",
  "ui.aboutGearScore.upgradeScore2": "100 is the reference value meaning exotic (or above) sigils/runes were equipped, as well as a relic.",
  "ui.aboutGearScore.upgradeScore3": "For the runes the synergy is also checked.",
  "ui.aboutGearScore.upgradeScore4": "Meaning that having 4 matching runes and 2 other matching runes increases the gearscore, but not as much as 6 matching ones would.",
  "ui.aboutGearScore.weaponCountHeader": "Weapon Count",
  "ui.aboutGearScore.weaponCount1": "Since builds can have a different amount of weapons, it is only checked how many *should* be equipped compared to the actual equipped ones.",
  "ui.aboutGearScore.weaponCount2": "As such, having only one one-handed weapon, means you *should* have (at least) two. The score is calculated based on two.",
  "ui.aboutGearScore.weaponCount3": "Equally if an elementalist or engineer has a second set, both sets are factored into the score, if a second set is used.",
  "ui.aboutGearScore.scoreColorsHeader": "Score Colors",
  "ui.aboutGearScore.color.basic": "Basic. Score below or equal 124",
  "ui.aboutGearScore.color.fine": "Fine. Score above 124",
  "ui.aboutGearScore.color.masterwork": "Masterwork. Score above 139",
  "ui.aboutGearScore.color.rare": "Rare. Score above 155",
  "ui.aboutGearScore.color.exotic": "Exotic. Score above 177",
  "ui.aboutGearScore.color.ascended": "Ascended. Score above 200",
  "ui.aboutGearScore.color.legendary": "Legendary. Perfect score. (206)",
  "ui.aboutGearScore.footer": "The score is calculated based on a fully geared character with equipment of the equivalent rarity at level 80.",
